<IfModule mod_rewrite.c>
    RewriteEngine On

    # If requesting a real file in /public — serve it directly
    RewriteCond %{REQUEST_URI} ^/geoguess/public/
    RewriteRule ^ - [L]

    # Rewrite everything else through the root index.php (which bootstraps Laravel)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
